rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- UserProgress Validation ---
    function isValidUserProgress(data) {
      return data.uid is string 
        && data.uid.size() <= 128
        && data.hearts is int
        && data.hearts >= 0
        && data.hearts <= 10
        && data.stars is int
        && data.stars >= 0
        && data.wrongAnswers is list
        && (data.currentMission == null || data.currentMission is string)
        && (data.lastSessionDate == null || data.lastSessionDate is string);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUserProgress(incoming())
        && incoming().uid == userId
        && incoming().keys().hasAll(['uid', 'hearts', 'stars', 'wrongAnswers'])
        // Relaxing size check slightly for system fields like createdAt but enforcing core
        && incoming().stars == 0;

      allow update: if isOwner(userId)
        && isValidUserProgress(incoming())
        && incoming().uid == existing().uid
        && (
          // Action: Update Stars/Hearts
          incoming().diff(existing()).affectedKeys().hasOnly(['stars', 'hearts', 'wrongAnswers', 'currentMission', 'lastSessionDate', 'questionCount'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['hearts', 'currentMission', 'lastSessionDate'])
        );
    }
  }
}
